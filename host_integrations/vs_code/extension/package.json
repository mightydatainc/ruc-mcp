{
  "name": "ruc-mcp-server",
  "displayName": "Render Unto Caesar (MCP Server)",
  "description": "Get the contextual intelligence of AI with the procedural rigor of code",
  "version": "0.1.5",
  "publisher": "mightydatainc",
  "license": "MIT",
  "icon": "assets/render-unto-caesar-128-tight.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "copilot",
    "cursor",
    "tools",
    "ruc"
  ],
  "scripts": {
    "build": "npm run package:vsix",
    "install": "code --install-extension ./build/ruc-mcp-server.vsix",
    "package:vsix": "node -e \"require('fs').mkdirSync('build',{recursive:true})\" && npx vsce package --out ./build/ruc-mcp-server.vsix",
    "publish": "npm run vsce:publish && npm run openvsx:publish",
    "vsce:login": "dotenv -e .env -- npx vsce login mightydatainc",
    "vsce:publish": "dotenv -e .env -- npx vsce publish",
    "openvsx:create-namespace": "dotenv -e .env -- npx ovsx create-namespace mightydatainc",
    "openvsx:publish": "dotenv -e .env -- npx ovsx publish",
    "openvsx:publish:vsix": "dotenv -e .env -- npx ovsx publish ./build/ruc-mcp-server.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "dotenv-cli": "^8.0.0",
    "ovsx": "^0.10.5"
  },
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "mightydatainc.ruc-mcp-provider",
        "label": "Run AI tasks with the reliability of procedural code"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mightydatainc/ruc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mightydatainc/ruc-mcp/issues"
  },
  "homepage": "https://mightydatainc.com/"
}
