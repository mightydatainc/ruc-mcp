{
  "name": "ruc-mcp-server",
  "displayName": "Render Unto Caesar (MCP Server)",
  "description": "Interweave the semantic judgment of LLMs with the procedural rigor of code.",
  "version": "0.1.3",
  "publisher": "mighty-data-inc",
  "license": "MIT",
  "icon": "assets/render-unto-caesar-128-tight.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "copilot",
    "tools",
    "ruc"
  ],
  "scripts": {
    "build": "npm run package:vsix",
    "package:vsix": "node -e \"require('fs').mkdirSync('build',{recursive:true})\" && vsce package --out build/ruc-mcp-server.vsix",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "mighty-data-inc.ruc-mcp-provider",
        "label": "Render Unto Caesar"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Mighty-Data-Inc/ruc-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Mighty-Data-Inc/ruc-mcp/issues"
  },
  "homepage": "https://github.com/Mighty-Data-Inc/ruc-mcp"
}
