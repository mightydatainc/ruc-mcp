{
  "mcpServers": {
    "Render Unto Caesar (\"RUC\")": {
      "type": "stdio",
      "command": "docker",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "RUC_MCP_LOG_LEVEL=DEBUG",
        "-e",
        "RUC_MCP_HOST_WORKSPACE=${workspaceFolder}",
        "-v",
        "${workspaceFolder}:/workspace",
        "ghcr.io/mightydatainc/ruc-mcp:latest"
      ]
    }
  }
}