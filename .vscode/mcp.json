{
  "servers": {
    "ruc-mcp": {
      "type": "stdio",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "args": ["-m", "ruc_mcp.server"],
      "env": {
        "RUC_MCP_LOG_LEVEL": "DEBUG",
        "RUC_MCP_LOG_FILE": "${workspaceFolder}\\ruc-mcp.log"
      }
    }
  }
}
