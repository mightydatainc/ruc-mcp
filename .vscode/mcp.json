{
  "servers": {
    "Render Unto Caesar (\"RUC\")": {
      "type": "stdio",
      "command": "docker",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "RUC_MCP_LOG_LEVEL=DEBUG",
        "-v",
        "${workspaceFolder}:/workspace",
        "mightydatainc/ruc-mcp:local"
      ]
    }
  }
}
