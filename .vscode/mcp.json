{
  "servers": {
    "Render Unto Caesar": {
      "type": "stdio",
      "command": "docker",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "RUC_MCP_LOG_LEVEL=DEBUG",
        "-v",
        "${workspaceFolder}:/workspace",
        "ghcr.io/mighty-data-inc/ruc-mcp:latest"
      ]
    }
  }
}
